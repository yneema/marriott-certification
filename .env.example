# Copy this file to .env and fill in your values
# (Never commit .env to git)

SIMPLIFY_EMAIL=your-vendor-login@example.com
SIMPLIFY_PASSWORD=your-password-here

# Just the folder ID — not the full URL.
# Defaults to the Marriott Shared Drive (0AKKb9XtARP0zUk9PVA) if left unset.
# Example: from https://drive.google.com/drive/u/0/folders/0AKKb9XtARP0zUk9PVA
#          the ID is: 0AKKb9XtARP0zUk9PVA
GOOGLE_DRIVE_FOLDER_ID=0AKKb9XtARP0zUk9PVA

# Paste the full contents of your service account JSON here (single line),
# OR leave this unset and place the .json key file next to simplify_fetch.py
GOOGLE_SERVICE_ACCOUNT_JSON=
